apt install rsyslog-mysql
nano /etc/rsyslog.conf/rules.conf

module(load="imudp")
input(type="imudp" port="514")

module(load="imtcp")
input(type="imtcp" port="514")

module(load="ommysql")

# R-SRV для записи в бд
if $hostname == 'R-SRV' then {
    action(type="ommysql" server="127.0.0.1" db="Syslog" user="rsyslog" pass="rsyslog_pass")
    stop 
}

# L-SRV для записи authpriv (смена пользователя, успешные или неудачный входы, использование sudo. используется для закрытой или привилегированной аутентификации)
if $hostname == 'L-SRV' then {
    if $syslogfacility-text == 'authpriv' then {
        action(type="omfile" file="/opt/error/L-SRV/auth.log")
    }
    stop
}

# L-FW для записи auth ( смена пользователя, успешные или неудачный входы, использование sudo. отвечает за общую аутентификацию) и err ( указывает на уровень важности сообщений, имеет 3 уровлень)
if $hostname == 'L-FW' then {
    if $syslogfacility-text == 'auth' or $syslogpriority-text == 'err' then {
        action(type="omfile" file="/opt/error/L-FW/super.log")
    }
    stop
}

# L-RTR-A для записи err ( указывает на уровень важности сообщений, имеет 3 уровлень)
if $hostname == 'L-RTR-A' then {
    if $syslogpriority-text == 'err' then {
        action(type="omfile" file="/opt/error/L-RTR-A/error.log")
    }
    stop
}

# L-RTR-B для записи auth ( смена пользователя, успешные или неудачный входы, использование sudo. отвечает за общую аутентификацию)
if $hostname == 'L-RTR-B' then {
    if $syslogfacility-text == 'auth' or $syslogfacility-text == 'authpriv' then {
        action(type="omfile" file="/opt/error/L-RTR-B/auth.log")
    }
    stop
}

systemctl restart rsyslog

# На клиенте
nano /etc/rsyslog.conf
*.*@192.168.1.1:514 # Отправка логов по UDP
*.*@@192.168.1.1:514 # Отправка логов по TCP



